# App settings
AVANT_APP_ENV=dev
AVANT_LOG_LEVEL=INFO
AVANT_POSTGRES_HOST=localhost
AVANT_POSTGRES_PORT=5432
AVANT_POSTGRES_DB=avant_exec_dashboard
AVANT_POSTGRES_USER=postgres
AVANT_POSTGRES_PASSWORD=postgres
AVANT_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/avant_exec_dashboard
AVANT_TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
AVANT_DEFILLAMA_BASE_URL=https://coins.llama.fi
AVANT_DEFILLAMA_YIELDS_BASE_URL=https://yields.llama.fi
AVANT_REQUEST_TIMEOUT_SECONDS=15
AVANT_EVM_RPC_URLS={"ethereum":"https://your-ethereum-rpc","avalanche":"https://your-avalanche-rpc"}
AVANT_SOLANA_RPC_URLS={"solana":"https://your-solana-rpc"}
AVANT_STACKS_API_BASE_URL=https://api.hiro.so
AVANT_ZEST_API_BASE_URL=
AVANT_KAMINO_API_BASE_URL=https://api.kamino.finance
AVANT_SILO_API_BASE_URL=https://app.silo.finance
AVANT_SILO_POINTS_API_BASE_URL=https://api-points.silo.finance
AVANT_SILO_TOP_HOLDERS_LIMIT=50
AVANT_DEBANK_CLOUD_API_KEY=REMOVED_DEBANK_KEY

# Docker Compose local Postgres defaults
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=avant_exec_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional local DB UI
ADMINER_PORT=8080
